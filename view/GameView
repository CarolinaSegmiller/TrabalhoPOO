package view;

import java.awt.BorderLayout;
import java.awt.Font;
import java.awt.GridLayout;
import java.text.DecimalFormat;

import javax.swing.Box;
import javax.swing.BoxLayout;
import javax.swing.DefaultListModel;
import javax.swing.JButton;
import javax.swing.JFrame;
import javax.swing.JLabel;
import javax.swing.JList;
import javax.swing.JOptionPane;
import javax.swing.JPanel;
import javax.swing.JScrollPane;
import javax.swing.JTextArea;
import javax.swing.ListSelectionModel;
import javax.swing.border.EmptyBorder;

import controle.GameController;
import modelo.Pais;

ublic class GameView extends JFrame {

    private final GameController controller = new GameController();

    private final DefaultListModel<Pais> listModel = new DefaultListModel<>();
    private final JList<Pais> listaCartas = new JList<>(listModel);

    private final JButton btnJogar = new JButton("JOGAR");
    private final JLabel lblRodada = new JLabel("Pontuação da Rodada: Você 0 x 0 Máquina");
    private final JLabel lblGeral  = new JLabel("Pontuação Geral: Você 0 x 0 Máquina");
    private final JLabel lblVencedor = new JLabel("Vencedor: -");

    // Painéis de “cartas”
    private final JTextArea areaHumano = new JTextArea();
    private final JTextArea areaMaquina = new JTextArea();

    // Marcadores (✓ / ✗)
    private final JLabel mkArea = new JLabel("-");
    private final JLabel mkPop  = new JLabel("-");
    private final JLabel mkVida = new JLabel("-");
    private final JLabel mkRenda= new JLabel("-");
    private final JLabel mkDens = new JLabel("-");

    private final DecimalFormat df = new DecimalFormat("#,##0.00");

    public GameView() {
        setTitle("Super Trunfo - Países (MVC + MySQL)");
        setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        setSize(1000, 650);
        setLocationRelativeTo(null);

        JPanel root = new JPanel(new BorderLayout(12, 12));
        root.setBorder(new EmptyBorder(12, 12, 12, 12));
        setContentPane(root);

        // Coluna esquerda: lista de cartas do jogador
        JPanel left = new JPanel(new BorderLayout(8,8));
        left.add(new JLabel("Suas cartas:"), BorderLayout.NORTH);
        listaCartas.setSelectionMode(ListSelectionModel.SINGLE_SELECTION);
        left.add(new JScrollPane(listaCartas), BorderLayout.CENTER);
        left.add(btnJogar, BorderLayout.SOUTH);

        // Centro: comparação
        JPanel center = new JPanel(new GridLayout(1, 2, 10, 10));
        setupTextArea(areaHumano);
        setupTextArea(areaMaquina);

        JPanel cardH = new JPanel(new BorderLayout());
        cardH.add(new JLabel("Você"), BorderLayout.NORTH);
        cardH.add(new JScrollPane(areaHumano), BorderLayout.CENTER);

        JPanel cardM = new JPanel(new BorderLayout());
        cardM.add(new JLabel("Máquina"), BorderLayout.NORTH);
        cardM.add(new JScrollPane(areaMaquina), BorderLayout.CENTER);

        center.add(cardH);
        center.add(cardM);

        // Direita: marcadores + placar
        JPanel right = new JPanel();
        right.setLayout(new BoxLayout(right, BoxLayout.Y_AXIS));

        right.add(new JLabel("Resultado por atributo (Você):"));
        right.add(Box.createVerticalStrut(8));
        right.add(row("Área", mkArea));
        right.add(row("População", mkPop));
        right.add(row("Expect. Vida", mkVida));
        right.add(row("Renda p/ cap", mkRenda));
        right.add(row("Densidade", mkDens));

        right.add(Box.createVerticalStrut(12));
        right.add(lblRodada);
        right.add(Box.createVerticalStrut(8));
        right.add(lblGeral);
        right.add(Box.createVerticalStrut(8));
        right.add(lblVencedor);

        root.add(left, BorderLayout.WEST);
        root.add(center, BorderLayout.CENTER);
        root.add(right, BorderLayout.EAST);

        carregarCartas();

        btnJogar.addActionListener(e -> jogar());
    }

    private void setupTextArea(JTextArea ta) {
        ta.setEditable(false);
        ta.setFont(new Font(Font.MONOSPACED, Font.PLAIN, 14));
    }

    private JPanel row(String label, JLabel marker) {
        JPanel p = new JPanel(new BorderLayout());
        p.add(new JLabel(label), BorderLayout.WEST);
        marker.setFont(new Font(Font.SANS_SERIF, Font.BOLD, 18));
        p.add(marker, BorderLayout.EAST);
        return p;
    }

    private void carregarCartas() {
        listModel.clear();
        for (Pais p : controller.getCartasDisponiveis()) listModel.addElement(p);
    }

    private void jogar() {
        if (controller.terminou()) {
            JOptionPane.showMessageDialog(this, "Jogo terminou! Vencedor: " + controller.vencedorFinal());
            return;
        }

        Pais selecionada = listaCartas.getSelectedValue();
        if (selecionada == null) {
            JOptionPane.showMessageDialog(this, "Selecione uma carta na lista.");
            return;
        }

        var outcome = controller.jogarRodada(selecionada);

        // Mostrar cartas
        areaHumano.setText(formatarCarta(outcome.humano));
        areaMaquina.setText(formatarCarta(outcome.maquina));

        // Marcadores
        setMarker(mkArea, outcome.areaHumanoGanha, outcome.humano.getAreaKm2(), outcome.maquina.getAreaKm2());
        setMarker(mkPop,  outcome.popHumanoGanha,  outcome.humano.getPopulacao(), outcome.maquina.getPopulacao());
        setMarker(mkVida, outcome.vidaHumanoGanha, outcome.humano.getExpectativaVida(), outcome.maquina.getExpectativaVida());
        setMarker(mkRenda,outcome.rendaHumanoGanha,outcome.humano.getRendaPerCapita(), outcome.maquina.getRendaPerCapita());
        setMarker(mkDens, outcome.densHumanoGanha, outcome.humano.getDensidade(), outcome.maquina.getDensidade());

        lblRodada.setText("Pontuação da Rodada: Você " + outcome.pontosHumanoRodada + " x " + outcome.pontosMaquinaRodada + " Máquina");
        lblGeral.setText("Pontuação Geral: Você " + controller.getPontosHumanoTotal() + " x " + controller.getPontosMaquinaTotal() + " Máquina");

        carregarCartas(); // removeu cartas usadas

        if (controller.terminou()) {
            lblVencedor.setText("Vencedor: " + controller.vencedorFinal());
            JOptionPane.showMessageDialog(this, "Fim de jogo! Vencedor: " + controller.vencedorFinal());
        }
    }

    private void setMarker(JLabel label, boolean humanoGanha, double a, double b) {
        if (a == b) label.setText("=");
        else label.setText(humanoGanha ? "✓" : "✗");
    }

    private String formatarCarta(Pais p) {
        return ""
                + "País: " + p.getNome() + "\n"
                + "Área(km²): " + p.getAreaKm2() + "\n"
                + "População: " + p.getPopulacao() + "\n"
                + "Expect. Vida: " + df.format(p.getExpectativaVida()) + "\n"
                + "Renda p/ cap: " + df.format(p.getRendaPerCapita()) + "\n"
                + "Pessoas/km²: " + df.format(p.getDensidade()) + "\n";
    }
}
