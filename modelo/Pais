package modelo;

public class Pais {
    private int id;
    private String nome;
    private long areaKm2;
    private long populacao;
    private double expectativaVida;
    private double rendaPerCapita;
    private double densidade;

    public Pais(int id, String nome, long areaKm2, long populacao, double expectativaVida, double rendaPerCapita, double densidade) {
        this.id = id;
        this.nome = nome;
        this.areaKm2 = areaKm2;
        this.populacao = populacao;
        this.expectativaVida = expectativaVida;
        this.rendaPerCapita = rendaPerCapita;
        this.densidade = densidade;
    }

    public int getId() { return id; }
    public String getNome() { return nome; }
    public long getAreaKm2() { return areaKm2; }
    public long getPopulacao() { return populacao; }
    public double getExpectativaVida() { return expectativaVida; }
    public double getRendaPerCapita() { return rendaPerCapita; }
    public double getDensidade() { return densidade; }

    @Override
    public String toString() { return nome; }
}
